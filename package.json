{
  "name": "bitcoin-wallet",
  "version": "1.0.0",
  "description": "Production-grade Bitcoin HD Wallet with mainnet support",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/**/*.{ts,tsx}"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@tanstack/react-router": "^1.28.0",
    "bitcoinjs-lib": "^6.1.6",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "axios": "^1.6.5",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.2.1",
    "lucide-react": "^0.292.0",
    "zustand": "^4.4.1",
    "tiny-secp256k1": "^2.2.3"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "prettier": "^3.1.0"
  }
}
